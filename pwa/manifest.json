{
  "name": "PaginaWebPedidosPS - Sistema de Gestión de Pedidos",
  "short_name": "PedidosPS",
  "description": "Sistema web accesible para registrar y gestionar pedidos de negocio con integración a Excel en OneDrive",
  "start_url": "/index.html",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  
  "theme_color": "#0078d4",
  "background_color": "#ffffff",
  
  "icons": [
    {
      "src": "assets/images/logo-purple-shop.png",
      "sizes": "any",
      "type": "image/png",
      "purpose": "any"
    }
  ],

  "categories": [
    "business",
    "productivity"
  ],

  "shortcuts": [
    {
      "name": "Nuevo Pedido",
      "short_name": "Nuevo",
      "description": "Crear un nuevo pedido rápidamente",
      "url": "/index.html?action=new-order"
    },
    {
      "name": "Ver Pedidos",
      "short_name": "Pedidos",
      "description": "Ver lista de todos los pedidos",
      "url": "/index.html?action=list"
    },
    {
      "name": "Exportar Datos",
      "short_name": "Exportar",
      "description": "Exportar datos a JSON o Excel",
      "url": "/index.html?action=export"
    }
  ],
  
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": [
            "image/png",
            "image/jpeg",
            "application/json"
          ]
        }
      ]
    }
  },
  
  "protocol_handlers": [
    {
      "protocol": "web+pedidos",
      "url": "/index.html?protocol=%s"
    }
  ],
  
  "launch_handler": {
    "client_mode": [
      "navigate-new",
      "auto"
    ]
  },
  
  "note_taking": {
    "new_note_url": "/index.html?action=new-note"
  },
  
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "application/json": [
          ".json"
        ],
        "text/csv": [
          ".csv"
        ],
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": [
          ".xlsx"
        ]
      }
    }
  ],
  
  "manifest_version": 3,
  "version": "2.0.0",
  "author": {
    "name": "EdwingAlarcon",
    "url": "https://github.com/EdwingAlarcon"
  },
  "robots": "index, follow",
  "mobile_alternate": null,
  "prefer_related_applications": false,
  "related_applications": []
}
